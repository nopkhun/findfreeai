# ============================================================
# SML AI Router — Environment Variables
# ============================================================
# สำเนาไฟล์นี้เป็น .env แล้วใส่ค่าจริง:
#   cp .env.example .env
#
# บน Coolify: ตั้งค่าใน "Environment Variables" ใน UI แทน
# ============================================================

# ─── Runtime Mode + Network ─────────────────────────────────
# DEPLOY_MODE: local | docker | coolify
DEPLOY_MODE=local

# Runtime bind/ports
PROXY_HOST=0.0.0.0
PROXY_PORT=8900
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8898

# Key storage path (container แนะนำ /app/data/api_keys.json)
KEYS_FILE=api_keys.json

# ─── Coolify Domains (ตั้งใน Coolify UI) ─────────────────
DOMAIN_OPENCLAW=openclaw.yourdomain.com
DOMAIN_PROXY=proxy.yourdomain.com

# ─── API Keys (ใส่อย่างน้อย 1 ตัว) ─────────────────────
# Groq — สมัครฟรี https://console.groq.com/keys
GROQ_API_KEY=

# Cerebras — สมัครฟรี https://cloud.cerebras.ai/
CEREBRAS_API_KEY=

# SambaNova — สมัครฟรี https://cloud.sambanova.ai/apis
SAMBANOVA_API_KEY=

# OpenRouter (มี free models) — https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=

# NVIDIA NIM — https://build.nvidia.com/explore/discover
NVIDIA_API_KEY=

# Together AI — https://api.together.ai/settings/api-keys
TOGETHER_API_KEY=

# Mistral AI — https://console.mistral.ai/api-keys/
MISTRAL_API_KEY=

# DeepInfra — https://deepinfra.com/dash/api_keys
DEEPINFRA_API_KEY=

# Cohere — https://dashboard.cohere.com/api-keys
COHERE_API_KEY=
